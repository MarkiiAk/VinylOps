DATABASE_URL="file:./prisma/dev.db"

# Fase 7 (V1, seguridad) — ver lib/auth.ts.
# SESSION_SECRET: cadena aleatoria larga (32+ bytes en hex, por ejemplo) que
# firma las cookies de sesion. Genera la tuya con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=""

# ADMIN_USERNAME / ADMIN_PASSWORD: credenciales del PRIMER login. Solo se
# leen una vez, cuando todavia no existe ningun usuario administrador en la
# base — despues de eso las credenciales viven en la base (hasheadas) y
# estas variables ya no se usan.
ADMIN_USERNAME=""
ADMIN_PASSWORD=""
