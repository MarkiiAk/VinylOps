// VinylOps Pricing Studio — Prisma schema
// Datasource: SQLite (app privada, single-tenant, sin necesidad de servidor de DB)
// Generator: prisma-client (ESM client, ver ARCHITECTURE.md para el porqué de esta eleccion sobre prisma-client-js)

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Material {
  id                        String   @id @default(cuid())
  name                      String
  category                  String // Vinyl | Transfer | HTV | Cardstock | StickerPaper | Other
  color                     String?
  finish                    String? // Glossy | Matte | Metallic | Transparent | Other
  brand                     String?
  supplierDefault           String?
  unit                      String   @default("cm2")
  totalAreaCm2              Float    @default(0)
  totalValue                Float    @default(0)
  weightedAverageCostPerCm2 Float    @default(0)
  weightedAverageCostPerM2  Float    @default(0)
  lowStockThresholdCm2      Float    @default(0)
  isInventoryTracked        Boolean  @default(true) // false = "material de costo" (maquilado/pedido bajo demanda, sin stock real que trackear); true = inventario real que se compra y se va gastando
  sheetWidthCm              Float? // si el material se vende/usa por hoja de tamaño fijo (ej. 21.6 para tamaño carta), ancho de esa hoja
  sheetHeightCm             Float? // alto de esa hoja
  purchaseUrl               String? // link (Mercado Libre, tienda, etc.) de donde se compra este material
  isArchived                Boolean  @default(false)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  purchases           Purchase[]
  consumptions        InventoryConsumption[]
  catalogUsages       CatalogItemMaterial[]
  orderLineItemUsages OrderLineItem[]
}

model Purchase {
  id           String   @id @default(cuid())
  materialId   String
  material     Material @relation(fields: [materialId], references: [id])
  supplier     String?
  widthCm      Float
  heightCm     Float
  quantity     Float
  grossPrice   Float
  discount     Float    @default(0)
  finalPrice   Float
  totalAreaCm2 Float
  costPerCm2   Float
  costPerM2    Float
  purchaseDate DateTime @default(now())
  notes        String?
  createdAt    DateTime @default(now())
}

// Pedido (tarjeta de Kanban) ligado a un Lead: carrito tipo cotizacion con
// lineas de catalogo (precio fijo) + lineas "Otro" (100% manuales, ver
// QuoteLineItem). Reemplaza el Quote suelto de la version anterior — ahora
// todo pedido pertenece a un lead (catalogo de clientes), y un mismo lead
// puede acumular varios Order en el tiempo (historial). El status del Order
// es independiente del status del Lead: el Order avanza por las fases de
// produccion (Disenando..Entregado), el Lead por sus fases de relacion
// (Contacto..Cliente). Reemplaza tambien el flujo viejo de area x
// complejidad (lib/pricing, ya no se usa desde aqui, se deja intacto en el
// repo por si se reusa despues).
model Order {
  id           String    @id @default(cuid())
  leadId       String
  lead         Lead      @relation(fields: [leadId], references: [id])
  interest     String // que se vendio/se esta trabajando en ESTE pedido
  status       String    @default("Disenando") // Disenando | DisenoAprobado | Maquilando | Completado | Entregado
  notes        String?
  deliveryDate DateTime? // para el calendario de entregas (fase futura, campo listo desde ahora)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  lineItems    OrderLineItem[]
  payments     Payment[]
  consumptions InventoryConsumption[]
}

// Linea del carrito de un Order: catalogItemId presente = del catalogo de
// precio fijo (snapshot de nombre/precio al agregar); catalogItemId null =
// linea "Otro" 100% manual (descripcion libre + precio a mano). Las lineas
// "Otro" pueden declarar opcionalmente un material y area consumida, para
// poder descontar inventario cuando no hay receta automatica (ver
// updateOrderStatus en lib/actions/orders.ts).
//
// FASE 2 (V1, modelo financiero): cada linea congela, al momento de crearse,
// un snapshot completo de sus costos unitarios (material/tinta/luz/desgaste/
// merma/bolsa/etiquetita/mano de obra) y las ganancias/margenes derivados.
// Este snapshot NUNCA se recalcula despues aunque cambie el catalogo o el
// costo de un material — ver lib/costing.ts para las formulas exactas y
// freezeLineItemSnapshot en lib/actions/orders.ts para el punto donde se
// congela. Todos los campos de snapshot son nullable porque las 0 filas
// creadas antes de esta fase no tienen (ni necesitan) este desglose.
model OrderLineItem {
  id                   String       @id @default(cuid())
  orderId              String
  order                Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  catalogItemId        String?
  catalogItem          CatalogItem? @relation(fields: [catalogItemId], references: [id])
  description          String
  quantity             Int
  unitPrice            Float
  lineTotal            Float
  otherMaterialId      String?
  otherMaterial        Material?    @relation(fields: [otherMaterialId], references: [id])
  otherMaterialAreaCm2 Float?

  // --- snapshot financiero congelado (Fase 2, V1) ---
  unitMaterialCost    Float?
  unitInkCost         Float?
  unitElectricityCost Float?
  unitWearCost        Float?
  unitWasteCost       Float?
  unitBagCost         Float?
  unitLabelCost       Float?
  unitDirectCost      Float?
  totalDirectCost     Float?
  estimatedUnitLabor  Float?
  totalLabor          Float?
  lineGrossProfit     Float?
  lineGrossMargin     Float?
  profitAfterLabor    Float?
  marginAfterLabor    Float?
  frozenAt            DateTime?

  createdAt DateTime @default(now())
}

// Pago real recibido sobre un Order (anticipo o liquidacion). paidAt es la
// fecha REAL en que se recibio el dinero (para contabilidad semanal por
// fecha de pago, no de creacion del pedido) — createdAt es solo la fecha en
// que se capturo el registro en el sistema.
model Payment {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amount    Float
  type      String // "Anticipo" | "Liquidacion"
  paidAt    DateTime @default(now())
  notes     String?
  createdAt DateTime @default(now())
}

model InventoryConsumption {
  id                 String       @id @default(cuid())
  orderId            String?
  order              Order?       @relation(fields: [orderId], references: [id])
  catalogSaleId      String?
  catalogSale        CatalogSale? @relation(fields: [catalogSaleId], references: [id])
  materialId         String
  material           Material     @relation(fields: [materialId], references: [id])
  areaConsumedCm2    Float
  costConsumed       Float
  costPerCm2Snapshot Float
  consumedAt         DateTime     @default(now())
  notes              String?
}

// Catálogo de precio fijo (etiquetas escolares + kits) — segunda línea de
// venta del negocio, separada del flujo de pedidos custom (Order). Reusa
// InventoryConsumption (vía catalogSaleId) para descontar inventario con el
// mismo mecanismo que ya usa Order, sin duplicar esa tabla.
//
// FASE 2 (V1, modelo financiero): otherCostPerUnit queda como campo LEGADO
// (mezclaba tinta + luz + tiempo del dueño, sin poder separarse sin inventar
// datos financieros) — se conserva su valor histórico intacto pero deja de
// usarse en los cálculos nuevos. Los 8 campos granulares de abajo (incluye
// materialCostPerUnit) son la fuente de verdad de costo unitario en V1.
//
// REGLAS DE NEGOCIO (2026-07, dictadas por el dueño — fuente de verdad,
// ver V1_IMPLEMENTATION_REPORT.md): materialCostPerUnit es un valor QUE SE
// CAPTURA DIRECTO, igual que tinta/luz/desgaste/merma/mano de obra — NO se
// deriva del costo ponderado de inventario (weightedAverageCostPerCm2). La
// receta de materiales (`materials`/CatalogItemMaterial) sigue existiendo
// SOLO para el consumo/descuento de inventario real al completar un pedido;
// es un concepto separado del costeo de venta.
//
// Para un KIT (isKit=true): materialCostPerUnit, inkCostPerUnit,
// electricityCostPerUnit, wearCostPerUnit, wasteCostPerUnit y
// laborCostPerUnit de ESTE registro NO se usan — se derivan en vivo sumando
// esos mismos campos de cada componente (kitComponents) * su cantidad en el
// kit (ver deriveKitCosts en lib/costing.ts), para nunca duplicar
// información ni quedar desactualizados si cambia el costo de un producto.
// bagCostPerUnit/labelCostPerUnit SÍ son propios del kit (una bolsa y una
// etiquetita compartidas, no una por componente).
model CatalogItem {
  id                     String   @id @default(cuid())
  name                   String
  isKit                  Boolean  @default(false)
  unitPrice              Float
  otherCostPerUnit       Float    @default(0) // LEGADO: ver nota arriba, ya no se usa en calculos nuevos
  materialCostPerUnit    Float    @default(0) // material (capturado directo, no derivado de inventario)
  inkCostPerUnit         Float    @default(0) // tinta
  electricityCostPerUnit Float    @default(0) // luz
  wearCostPerUnit        Float    @default(0) // desgaste de maquina/herramienta
  wasteCostPerUnit       Float    @default(0) // provision de merma
  bagCostPerUnit         Float    @default(0) // bolsa (compartida, 1 por kit cuando isKit)
  labelCostPerUnit       Float    @default(0) // etiquetita (compartida, 1 por kit cuando isKit)
  laborCostPerUnit       Float    @default(0) // mano de obra estimada
  description            String?
  isActive               Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  materials      CatalogItemMaterial[]
  sales          CatalogSale[]
  orderLineItems OrderLineItem[]

  // Componentes de un kit (solo relevante cuando isKit=true): que productos
  // del catalogo y en que cantidad lo integran, para poder mostrar "precio
  // normal equivalente" y ahorro vs comprar por separado. Independiente de
  // `materials` (la receta de materia prima real, usada para costo/
  // inventario) — un kit tiene AMBAS: su propia receta de materiales (para
  // costo/consumo) y su lista de componentes (para el calculo de ahorro).
  kitComponents   CatalogItemComponent[] @relation("KitComponents")
  componentOfKits CatalogItemComponent[] @relation("ComponentOf")
}

// Componente de un kit: cuantas unidades de otro CatalogItem (vendido tambien
// por separado) incluye este kit. quantity puede ser fraccionaria (ej. 0.5 =
// media hoja/carta) porque un kit puede incluir medio producto individual.
model CatalogItemComponent {
  id              String      @id @default(cuid())
  kitId           String
  kit             CatalogItem @relation("KitComponents", fields: [kitId], references: [id], onDelete: Cascade)
  componentItemId String
  componentItem   CatalogItem @relation("ComponentOf", fields: [componentItemId], references: [id])
  quantity        Float
  createdAt       DateTime    @default(now())
}

model CatalogItemMaterial {
  id             String      @id @default(cuid())
  catalogItemId  String
  catalogItem    CatalogItem @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)
  materialId     String
  material       Material    @relation(fields: [materialId], references: [id])
  areaCm2PerUnit Float // cm2 de este material que consume UNA unidad vendida del item/kit
}

model CatalogSale {
  id                String      @id @default(cuid())
  catalogItemId     String
  catalogItem       CatalogItem @relation(fields: [catalogItemId], references: [id])
  quantity          Int
  unitPriceSnapshot Float // precio del CatalogItem al momento de vender (congelado, igual criterio que weightedAverageCostSnapshot en Quote)
  totalPrice        Float
  customerName      String?
  notes             String?
  createdAt         DateTime    @default(now())

  consumptions InventoryConsumption[]
}

// Catalogo de clientes: cada Lead es un contacto real de WhatsApp, con su
// propio historial de pedidos (Order) a lo largo del tiempo. El status del
// Lead refleja la relacion comercial (Contacto -> Ganado -> Cliente, con
// Pendiente/Perdido como excepciones), NO el avance de un pedido puntual
// (eso vive en Order.status). Un lead puede volver meses despues con un
// pedido nuevo — cada Order es independiente pero pertenece al mismo Lead.
model Lead {
  id        String   @id @default(cuid())
  name      String?
  phone     String?
  notes     String? // notas generales del contacto, no de un pedido en particular
  status    String   @default("Contacto") // Contacto | Pendiente | Ganado | Cliente | Perdido
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]
}

model Settings {
  id                          String   @id @default(cuid())
  currency                    String   @default("MXN")
  defaultComplexityFactor     Float    @default(3.5)
  defaultMinimumPricePerPiece Float    @default(8)
  defaultMinimumJobPrice      Float    @default(300)
  defaultWastePercentage      Float    @default(0)
  premiumMultiplier           Float    @default(1.10)
  minimumAcceptableMultiplier Float    @default(0.90)
  roundingRule                String   @default("nearest10")
  businessName                String   @default("VinylOps")
  ownerName                   String?
  theme                       String   @default("dark")
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
}
